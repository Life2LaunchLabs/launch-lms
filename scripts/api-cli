#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
API_DIR="$ROOT_DIR/apps/api"
VENV_PYTHON="$API_DIR/.venv/bin/python"

if [[ -x "$VENV_PYTHON" ]]; then
  exec "$VENV_PYTHON" "$API_DIR/cli.py" "$@"
fi

if command -v uv >/dev/null 2>&1; then
  cd "$API_DIR"
  exec uv run python cli.py "$@"
fi

echo "Unable to find an API Python environment." >&2
echo "Expected $VENV_PYTHON or a working 'uv' installation." >&2
exit 1
